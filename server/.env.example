# Copie para .env e ajuste os valores.
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Gere um segredo longo e aleatório (nunca commite o .env real).
JWT_SECRET=cole-aqui-uma-string-aleatoria-com-pelo-menos-32-caracteres

ADMIN_USERNAME=Rafael

# Hash bcrypt da senha (nunca armazene senha em texto puro).
# Gere com: npm run hash-password -- "sua_senha"
ADMIN_PASSWORD_HASH=$2b$12$iPwjSz/yqrQZ61XPeKjlL.CUDtLnC10P9fRsFLk64YoQ/w2IukP1i

# Opcional: nome do cookie JWT
# COOKIE_NAME=procedi_token

# Opcional: máximo de tentativas de login falhas por IP / 15 min (padrão 8)
# LOGIN_RATE_LIMIT_MAX=8
